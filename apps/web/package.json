{
  "name": "@mailkite/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta \"tsx watch src/node.ts\" \"vite\"",
    "dev:api": "tsx watch src/node.ts",
    "dev:web": "vite",
    "start": "tsx src/node.ts",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "deploy": "vite build && wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply mailkite-mail --remote",
    "db:migrate:local": "wrangler d1 migrations apply mailkite-mail --local"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@mailkite/core": "workspace:*",
    "@mailkite/ui": "workspace:*",
    "hono": "^4.9.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^10.0.3",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.8",
    "wrangler": "^3.99.0"
  }
}
